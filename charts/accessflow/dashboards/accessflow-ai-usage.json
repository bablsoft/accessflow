{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "AccessFlow — AI Usage",
  "uid": "accessflow-ai-usage",
  "tags": ["accessflow"],
  "schemaVersion": 39,
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "AI analyses (per s, by provider & outcome)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider, outcome) (rate(accessflow_ai_analyze_seconds_count[5m]))",
          "legendFormat": "{{provider}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "AI analyze latency (avg) by provider",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (provider) (rate(accessflow_ai_analyze_seconds_sum[5m])) / clamp_min(sum by (provider) (rate(accessflow_ai_analyze_seconds_count[5m])), 0.001)",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Token consumption (per s, by type)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (type) (rate(accessflow_ai_tokens_sum[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tokens consumed (last 24h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(accessflow_ai_tokens_sum[24h]))",
          "legendFormat": "tokens"
        }
      ]
    },
    {
      "id": 5,
      "title": "Risk-level mix (1h)",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (risk_level) (increase(accessflow_ai_analyze_seconds_count[1h]))",
          "legendFormat": "{{risk_level}}"
        }
      ]
    }
  ]
}
