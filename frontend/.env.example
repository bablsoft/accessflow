# These VITE_* variables are read at build time (npm run dev / npm run build) and
# baked into the bundle. They are for local development only.
#
# Production deployments override the same two values at runtime by replacing
# public/runtime-config.js in the served static root (see docs/09-deployment.md
# -> "Frontend Runtime Configuration"). The runtime file takes precedence over
# these build-time defaults.
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
