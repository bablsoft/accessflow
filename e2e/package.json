{
  "name": "accessflow-e2e",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "End-to-end Playwright suite for AccessFlow. Spins up Postgres + Redis + backend + frontend via docker-compose.e2e.yml and exercises the real auth flow.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:setup": "playwright test --config=playwright.setup.config.ts",
    "test:sso": "playwright test --config=playwright.sso.config.ts",
    "stack:up": "docker compose -f docker-compose.e2e.yml up --build -d --wait",
    "stack:down": "docker compose -f docker-compose.e2e.yml down -v",
    "stack:logs": "docker compose -f docker-compose.e2e.yml logs --tail=200",
    "stack:setup:up": "docker compose -f docker-compose.e2e.setup.yml up --build -d --wait",
    "stack:setup:down": "docker compose -f docker-compose.e2e.setup.yml down -v",
    "stack:setup:logs": "docker compose -f docker-compose.e2e.setup.yml logs --tail=200",
    "stack:sso:up": "docker compose -f docker-compose.e2e.sso.yml up --build -d --wait",
    "stack:sso:down": "docker compose -f docker-compose.e2e.sso.yml down -v",
    "stack:sso:logs": "docker compose -f docker-compose.e2e.sso.yml logs --tail=200",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "otplib": "^13.4.0",
    "typescript": "^6.0.3"
  }
}
